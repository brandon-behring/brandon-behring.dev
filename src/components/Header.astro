---
type HeaderVariant = "full" | "minimal";

interface Props {
  variant?: HeaderVariant;
}

const { variant = "full" } = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Home", match: "exact" as const },
  { href: "/work/", label: "Work", match: "prefix" as const },
  { href: "/lab/", label: "Lab", match: "prefix" as const },
  { href: "/publications/", label: "Publications", match: "prefix" as const },
  { href: "/research/", label: "Research", match: "prefix" as const },
  { href: "/how-this-was-made/", label: "How this was made", match: "prefix" as const },
  { href: "/#about", label: "About", match: "none" as const },
  { href: "/#contact", label: "Contact", match: "none" as const },
];

function isActive(item: { href: string; match: string }): boolean {
  if (item.match === "exact") return currentPath === item.href;
  if (item.match === "prefix") return currentPath.startsWith(item.href);
  return false;
}
---

<header class="site-header" data-variant={variant}>
  <div class="site-header-inner">
    <a href="/" class="brand">Brandon Behring</a>
    {variant === "full" ? (
      <nav aria-label="Site navigation" class="site-nav">
        {/* CSS-only disclosure: inline row on desktop, hamburger dropdown on mobile (no JS). */}
        <details class="nav-disclosure">
          <summary class="nav-toggle">
            <span class="nav-toggle-bars" aria-hidden="true"></span>
            <span class="nav-toggle-label">Menu</span>
          </summary>
          <ul class="nav-list">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[{ active: isActive(item) }]}
                  aria-current={isActive(item) ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </details>
      </nav>
    ) : (
      <a href="/" class="back-home" aria-label="Back to homepage">
        <span aria-hidden="true">&larr;</span> Home
      </a>
    )}
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
  }
  .site-header-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }
  .brand {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
  }
  .brand:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* --- Disclosure nav (mobile-first: hidden behind a hamburger) --- */
  .nav-disclosure { position: relative; }
  .nav-toggle {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    padding: 0.3rem 0.1rem;
  }
  .nav-toggle::-webkit-details-marker { display: none; }
  .nav-toggle-bars,
  .nav-toggle-bars::before,
  .nav-toggle-bars::after {
    content: "";
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
  }
  .nav-toggle-bars { position: relative; }
  .nav-toggle-bars::before { position: absolute; top: -5px; left: 0; }
  .nav-toggle-bars::after { position: absolute; top: 5px; left: 0; }
  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 3px;
  }
  /* Icon-only hamburger, but keep "Menu" as the accessible name for screen readers. */
  .nav-toggle-label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }
  .nav-disclosure:not([open]) .nav-list { display: none; }
  .nav-disclosure[open] .nav-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    position: absolute;
    right: 0;
    top: calc(100% + 0.6rem);
    min-width: 13rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--elevation-card, 0 4px 16px rgba(0,0,0,0.12));
    padding: 1rem 1.25rem;
    z-index: 50;
  }

  nav a {
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  nav a:hover,
  nav a:focus-visible { color: var(--color-accent); }
  nav a.active {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }

  /* --- Desktop: drop the hamburger, show an inline row --- */
  @media (min-width: 820px) {
    .nav-toggle { display: none; }
    /* Match the (0,3,0) specificity of the mobile `:not([open])` hide rule and
       come later in source order, so the inline desktop row always wins. */
    .nav-disclosure:not([open]) .nav-list,
    .nav-disclosure[open] .nav-list {
      display: flex;
      flex-direction: row;
      gap: 1.25rem;
      position: static;
      min-width: 0;
      background: none;
      border: 0;
      box-shadow: none;
      padding: 0;
    }
  }

  .back-home {
    color: var(--color-text-muted);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .back-home:hover,
  .back-home:focus-visible {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  @media (prefers-reduced-motion: reduce) {
    nav a,
    .back-home { transition: none; }
  }
</style>
