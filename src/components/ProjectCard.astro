---
interface Props {
  project: {
    slug: string;
    title: string;
    category: string;
    summary: string;
    metrics: string[];
    stack: string[];
    repo_url?: string;
    site_url?: string;
  };
}
const { project } = Astro.props;
---
<article class="project-card">
  <h3>{project.title}</h3>
  <p class="category">{project.category}</p>
  <p class="summary">{project.summary}</p>
  {project.metrics.length > 0 && (
    <ul class="metrics">
      {project.metrics.map((m) => <li>{m}</li>)}
    </ul>
  )}
  <p class="stack">
    <strong>Stack:</strong> {project.stack.join(' · ')}
  </p>
  <p class="links">
    {project.repo_url && <a href={project.repo_url}>Source ↗</a>}
    {project.site_url && <a href={project.site_url}>Live ↗</a>}
  </p>
</article>

<style>
  .project-card { padding: 1.25rem 0; border-bottom: 1px solid var(--color-border); }
  .project-card:last-child { border-bottom: none; }
  .project-card h3 { margin-top: 0.5rem; margin-bottom: 0.25rem; }
  .category { color: var(--color-text-muted); font-family: var(--font-sans); font-size: 0.85em; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 0.75rem 0; }
  .summary { margin: 0.5rem 0; }
  .metrics { margin: 0.5rem 0; padding-left: 1.25rem; font-family: var(--font-mono); font-size: 0.9em; }
  .metrics li { margin: 0.15rem 0; }
  .stack { font-size: 0.9em; color: var(--color-text-muted); }
  .links a { margin-right: 1rem; font-family: var(--font-sans); font-size: 0.92em; }
</style>
