---
// Interactive Δ-slider: where do discrete eigenvalues land as the step size
// grows? Plots six continuous modes (left half-plane) under two
// discretizations — ZOH e^{λΔ} (A-stable: inside the unit disk for every Δ)
// vs forward Euler 1 + λΔ (escapes once Δ crosses each mode's threshold).
// Deliberately two methods only: this illustrates the stability dichotomy,
// not a stability-region atlas.
// Per-instance id suffix so multiple sliders on one page can't collide on
// ids (the client script looks elements up structurally; ids are for a11y only).
const uid = crypto.randomUUID().slice(0, 8);
---

<div class="eigen-slider">
  <canvas id={`es-canvas-${uid}`} width="560" height="560">
    Interactive plot: six left-half-plane eigenvalues mapped into the complex
    plane by ZOH and forward Euler as the step size Δ varies. ZOH keeps every
    eigenvalue inside the unit disk for all Δ; forward Euler pushes them out
    as Δ grows.
  </canvas>
  <noscript>
    <p class="es-noscript">
      The interactive version needs JavaScript — the static figures above tell
      the same story.
    </p>
  </noscript>
  <div class="es-controls">
    <label for={`es-delta-${uid}`}>Step size Δ</label>
    <input type="range" id={`es-delta-${uid}`} min="0.01" max="1.5" step="0.01" value="0.4" />
    <output id={`es-status-${uid}`} for={`es-delta-${uid}`} aria-live="off"></output>
    <span id={`es-announce-${uid}`} class="sr-only" aria-live="polite"></span>
  </div>
  <p class="es-legend">
    <span class="es-swatch es-swatch-zoh" aria-hidden="true"></span> ZOH
    <span class="es-mu">μ = e<sup>λΔ</sup></span>
    &nbsp;·&nbsp;
    <span class="es-swatch es-swatch-euler" aria-hidden="true"></span> forward Euler
    <span class="es-mu">μ = 1 + λΔ</span>
    &nbsp;·&nbsp; gray circle = stability boundary
  </p>
</div>

<style>
  .eigen-slider {
    /* --es-zoh hand-synced to the site accent (tokens.css). Kept as a literal hex,
       not var(--color-accent): getComputedStyle() on an unregistered custom property
       won't reliably resolve a nested var(), and the canvas needs a real color. */
    --es-zoh: #3b6fa0;
    --es-euler: #bb5566;
    --es-grid: #cccccc;
    --es-text: #555555;
    --es-disk: rgba(68, 119, 170, 0.08);
    margin: 2rem 0;
    font-family: var(--font-sans);
  }
  @media (prefers-color-scheme: dark) {
    .eigen-slider {
      --es-zoh: #7fb0dd;
      --es-euler: #ee8899;
      --es-grid: #555555;
      --es-text: #aaaaaa;
      --es-disk: rgba(119, 170, 221, 0.12);
    }
  }
  canvas {
    display: block;
    width: 100%;
    max-width: 560px;
    height: auto;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
  }
  .es-noscript {
    max-width: 560px;
    margin: 0.5rem auto 0 auto;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  .es-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    max-width: 560px;
    margin: 0.75rem auto 0 auto;
    font-size: 0.9rem;
  }
  .es-controls label {
    font-weight: 600;
    white-space: nowrap;
  }
  .es-controls input[type='range'] {
    flex: 1;
    min-width: 10rem;
    accent-color: var(--color-accent);
  }
  .es-controls input[type='range']:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 3px;
  }
  .es-controls output {
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
    width: 100%;
  }
  .es-legend {
    max-width: 560px;
    margin: 0.5rem auto 0 auto;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .es-mu {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
  .es-swatch {
    display: inline-block;
    width: 0.7em;
    height: 0.7em;
    border-radius: 50%;
    vertical-align: baseline;
  }
  .es-swatch-zoh {
    background: var(--es-zoh);
  }
  .es-swatch-euler {
    background: var(--es-euler);
  }
  /* Visually hidden but screen-reader available (copied from ClusterCard.astro);
     hosts the polite live region that announces the settled verdict on release. */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  function initEigenSlider(wrapper: HTMLElement) {
    // Lookups scoped to the component root; ids retained only for the
    // label[for]/output[for] associations.
    const canvas = wrapper.querySelector('canvas') as HTMLCanvasElement | null;
    const slider = wrapper.querySelector(
      'input[type="range"]'
    ) as HTMLInputElement | null;
    const status = wrapper.querySelector('output');
    const liveRegion = wrapper.querySelector('.sr-only');
    if (!canvas || !slider || !status) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Logical drawing size; the backing buffer is scaled by devicePixelRatio
    // so points and text stay crisp on HiDPI displays.
    const SIZE = 560;
    const dpr = window.devicePixelRatio || 1;
    canvas.width = SIZE * dpr;
    canvas.height = SIZE * dpr;
    ctx.scale(dpr, dpr);

    // Six left-half-plane modes: four real (HiPPO-flavored decay ladder) and
    // one lightly damped oscillatory pair — the fragile case for Euler.
    const LAMBDAS: Array<[number, number]> = [
      [-0.5, 0],
      [-1.0, 0],
      [-1.5, 0],
      [-2.5, 0],
      [-0.25, 1.4],
      [-0.25, -1.4],
    ];

    // Plot window chosen so every Euler point stays visible up to Δ = 1.5.
    const VIEW = { x0: -3.0, x1: 1.6, y0: -2.4, y1: 2.4 };
    const px = (re: number) => ((re - VIEW.x0) / (VIEW.x1 - VIEW.x0)) * SIZE;
    const py = (im: number) =>
      SIZE - ((im - VIEW.y0) / (VIEW.y1 - VIEW.y0)) * SIZE;

    const zoh = ([a, b]: [number, number], dt: number): [number, number] => {
      const r = Math.exp(a * dt);
      return [r * Math.cos(b * dt), r * Math.sin(b * dt)];
    };
    const euler = ([a, b]: [number, number], dt: number): [number, number] => [
      1 + a * dt,
      b * dt,
    ];
    const mag = ([re, im]: [number, number]) => Math.hypot(re, im);

    const cssVar = (name: string) =>
      getComputedStyle(wrapper).getPropertyValue(name).trim();
    // Read the canvas palette once (getComputedStyle is not free, and draw()
    // runs on every input event during a drag); refresh only on a scheme flip.
    const readPalette = () => ({
      zoh: cssVar('--es-zoh'),
      euler: cssVar('--es-euler'),
      grid: cssVar('--es-grid'),
      text: cssVar('--es-text'),
      disk: cssVar('--es-disk'),
    });
    let palette = readPalette();

    const eulerDiverged = (dt: number) =>
      LAMBDAS.filter((lam) => mag(euler(lam, dt)) > 1).length;

    function draw() {
      if (!ctx || !slider) return;
      const dt = parseFloat(slider.value);
      const colors = palette;

      ctx.clearRect(0, 0, SIZE, SIZE);

      // Unit disk (stable region for the discrete recurrence) + axes.
      const r = px(1) - px(0);
      ctx.beginPath();
      ctx.arc(px(0), py(0), r, 0, 2 * Math.PI);
      ctx.fillStyle = colors.disk;
      ctx.fill();
      ctx.strokeStyle = colors.grid;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      ctx.strokeStyle = colors.grid;
      ctx.lineWidth = 0.75;
      ctx.beginPath();
      ctx.moveTo(0, py(0));
      ctx.lineTo(SIZE, py(0));
      ctx.moveTo(px(0), 0);
      ctx.lineTo(px(0), SIZE);
      ctx.stroke();

      ctx.fillStyle = colors.text;
      ctx.font = '13px sans-serif';
      ctx.fillText('Re(μ)', SIZE - 48, py(0) - 8);
      ctx.fillText('Im(μ)', px(0) + 8, 16);

      for (const lam of LAMBDAS) {
        const z = zoh(lam, dt);
        const e = euler(lam, dt);

        // ZOH: filled circle.
        ctx.beginPath();
        ctx.arc(px(z[0]), py(z[1]), 6, 0, 2 * Math.PI);
        ctx.fillStyle = colors.zoh;
        ctx.fill();

        // Euler: filled triangle.
        ctx.beginPath();
        ctx.moveTo(px(e[0]), py(e[1]) - 7);
        ctx.lineTo(px(e[0]) - 6, py(e[1]) + 5);
        ctx.lineTo(px(e[0]) + 6, py(e[1]) + 5);
        ctx.closePath();
        ctx.fillStyle = colors.euler;
        ctx.fill();
      }
    }

    function statusText() {
      if (!slider) return '';
      const dt = parseFloat(slider.value);
      const out = eulerDiverged(dt);
      const eulerWord =
        out === 0 ? 'all 6 modes stable' : `${out} of 6 modes diverge`;
      return `Δ = ${dt.toFixed(2)} — ZOH: all 6 modes stable, every Δ · forward Euler: ${eulerWord}`;
    }
    // Visible output tracks the drag live (aria-live="off"); the polite region
    // announces only the settled verdict on release.
    function updateStatus() {
      if (status) status.textContent = statusText();
    }
    function announce() {
      if (liveRegion) liveRegion.textContent = statusText();
    }

    // Redraw continuously while dragging and keep the visible status in step;
    // the polite region announces only the settled verdict on release (a live
    // region updated per input event reads as spam).
    slider.addEventListener('input', () => {
      draw();
      updateStatus();
    });
    // On commit, re-sync the visible model BEFORE announcing, so a `change` that
    // arrives without a preceding `input` (e.g. a programmatic commit) can't leave
    // the visible output / canvas stale while the announcer reports the new value.
    slider.addEventListener('change', () => {
      draw();
      updateStatus();
      announce();
    });
    draw();
    updateStatus();

    // Test/automation seam (#36): signal that a slider has drawn, so the headless
    // verify-suite can assert the canvas actually rendered (not merely exists).
    (window as any).__esReady = true;
    // Palette seam (#55): lets the verify-suite confirm a scheme flip actually
    // refreshed the cached palette (not just that the canvas stayed non-blank).
    (window as any).__esPalette = () => palette;

    // Re-read the palette when the color scheme flips. Registered AFTER the first
    // draw + the ready seam, and FULLY feature-detected — matchMedia itself plus
    // the listener API — so a stripped webview can't throw and blank the canvas
    // (old Safari/WebView expose only addListener).
    if (typeof window.matchMedia === 'function') {
      const mq = window.matchMedia('(prefers-color-scheme: dark)');
      const onScheme = () => {
        palette = readPalette();
        draw();
      };
      if (mq.addEventListener) mq.addEventListener('change', onScheme);
      else if ((mq as any).addListener) (mq as any).addListener(onScheme);
    }
  }

  function initAll() {
    document
      .querySelectorAll<HTMLElement>('.eigen-slider')
      .forEach(initEigenSlider);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
</script>
