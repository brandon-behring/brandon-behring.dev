---
// Interactive Δ-slider: where do discrete eigenvalues land as the step size
// grows? Plots six continuous modes (left half-plane) under two
// discretizations — ZOH e^{λΔ} (A-stable: inside the unit disk for every Δ)
// vs forward Euler 1 + λΔ (escapes once Δ crosses each mode's threshold).
// Deliberately two methods only: this illustrates the stability dichotomy,
// not a stability-region atlas.
---

<div class="eigen-slider">
  <canvas id="es-canvas" width="560" height="560">
    Interactive plot: six left-half-plane eigenvalues mapped into the complex
    plane by ZOH and forward Euler as the step size Δ varies. ZOH keeps every
    eigenvalue inside the unit disk for all Δ; forward Euler pushes them out
    as Δ grows.
  </canvas>
  <div class="es-controls">
    <label for="es-delta">Step size Δ</label>
    <input type="range" id="es-delta" min="0.01" max="1.5" step="0.01" value="0.4" />
    <output id="es-status" for="es-delta" aria-live="polite"></output>
  </div>
  <p class="es-legend">
    <span class="es-swatch es-swatch-zoh" aria-hidden="true"></span> ZOH
    <span class="es-mu">μ = e<sup>λΔ</sup></span>
    &nbsp;·&nbsp;
    <span class="es-swatch es-swatch-euler" aria-hidden="true"></span> forward Euler
    <span class="es-mu">μ = 1 + λΔ</span>
    &nbsp;·&nbsp; gray circle = stability boundary
  </p>
</div>

<style>
  .eigen-slider {
    --es-zoh: #004488;
    --es-euler: #bb5566;
    --es-grid: #cccccc;
    --es-text: #555555;
    --es-disk: rgba(68, 119, 170, 0.08);
    margin: 2rem 0;
    font-family: var(--font-sans);
  }
  @media (prefers-color-scheme: dark) {
    .eigen-slider {
      --es-zoh: #77aadd;
      --es-euler: #ee8899;
      --es-grid: #555555;
      --es-text: #aaaaaa;
      --es-disk: rgba(119, 170, 221, 0.12);
    }
  }
  canvas {
    display: block;
    width: 100%;
    max-width: 560px;
    height: auto;
    margin: 0 auto;
  }
  .es-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    max-width: 560px;
    margin: 0.75rem auto 0 auto;
    font-size: 0.9rem;
  }
  .es-controls label {
    font-weight: 600;
    white-space: nowrap;
  }
  .es-controls input[type='range'] {
    flex: 1;
    min-width: 10rem;
    accent-color: var(--color-accent);
  }
  .es-controls output {
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
    width: 100%;
  }
  .es-legend {
    max-width: 560px;
    margin: 0.5rem auto 0 auto;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .es-mu {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
  .es-swatch {
    display: inline-block;
    width: 0.7em;
    height: 0.7em;
    border-radius: 50%;
    vertical-align: baseline;
  }
  .es-swatch-zoh {
    background: var(--es-zoh);
  }
  .es-swatch-euler {
    background: var(--es-euler);
  }
</style>

<script>
  function initEigenSlider() {
    const canvas = document.getElementById('es-canvas') as HTMLCanvasElement | null;
    const slider = document.getElementById('es-delta') as HTMLInputElement | null;
    const status = document.getElementById('es-status');
    if (!canvas || !slider || !status) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const wrapper = canvas.closest('.eigen-slider') as HTMLElement;

    // Six left-half-plane modes: four real (HiPPO-flavored decay ladder) and
    // one lightly damped oscillatory pair — the fragile case for Euler.
    const LAMBDAS: Array<[number, number]> = [
      [-0.5, 0],
      [-1.0, 0],
      [-1.5, 0],
      [-2.5, 0],
      [-0.25, 1.4],
      [-0.25, -1.4],
    ];

    // Plot window chosen so every Euler point stays visible up to Δ = 1.5.
    const VIEW = { x0: -3.0, x1: 1.6, y0: -2.4, y1: 2.4 };
    const W = canvas.width;
    const H = canvas.height;
    const px = (re: number) => ((re - VIEW.x0) / (VIEW.x1 - VIEW.x0)) * W;
    const py = (im: number) => H - ((im - VIEW.y0) / (VIEW.y1 - VIEW.y0)) * H;

    const zoh = ([a, b]: [number, number], dt: number): [number, number] => {
      const r = Math.exp(a * dt);
      return [r * Math.cos(b * dt), r * Math.sin(b * dt)];
    };
    const euler = ([a, b]: [number, number], dt: number): [number, number] => [
      1 + a * dt,
      b * dt,
    ];
    const mag = ([re, im]: [number, number]) => Math.hypot(re, im);

    const cssVar = (name: string) =>
      getComputedStyle(wrapper).getPropertyValue(name).trim();

    function draw() {
      if (!ctx || !canvas || !slider || !status) return;
      const dt = parseFloat(slider.value);
      const colors = {
        zoh: cssVar('--es-zoh'),
        euler: cssVar('--es-euler'),
        grid: cssVar('--es-grid'),
        text: cssVar('--es-text'),
        disk: cssVar('--es-disk'),
      };

      ctx.clearRect(0, 0, W, H);

      // Unit disk (stable region for the discrete recurrence) + axes.
      const r = px(1) - px(0);
      ctx.beginPath();
      ctx.arc(px(0), py(0), r, 0, 2 * Math.PI);
      ctx.fillStyle = colors.disk;
      ctx.fill();
      ctx.strokeStyle = colors.grid;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      ctx.strokeStyle = colors.grid;
      ctx.lineWidth = 0.75;
      ctx.beginPath();
      ctx.moveTo(0, py(0));
      ctx.lineTo(W, py(0));
      ctx.moveTo(px(0), 0);
      ctx.lineTo(px(0), H);
      ctx.stroke();

      ctx.fillStyle = colors.text;
      ctx.font = '13px sans-serif';
      ctx.fillText('Re(μ)', W - 48, py(0) - 8);
      ctx.fillText('Im(μ)', px(0) + 8, 16);

      let eulerOut = 0;
      for (const lam of LAMBDAS) {
        const z = zoh(lam, dt);
        const e = euler(lam, dt);
        if (mag(e) > 1) eulerOut += 1;

        // ZOH: filled circle.
        ctx.beginPath();
        ctx.arc(px(z[0]), py(z[1]), 6, 0, 2 * Math.PI);
        ctx.fillStyle = colors.zoh;
        ctx.fill();

        // Euler: filled triangle.
        ctx.beginPath();
        ctx.moveTo(px(e[0]), py(e[1]) - 7);
        ctx.lineTo(px(e[0]) - 6, py(e[1]) + 5);
        ctx.lineTo(px(e[0]) + 6, py(e[1]) + 5);
        ctx.closePath();
        ctx.fillStyle = colors.euler;
        ctx.fill();
      }

      const eulerWord =
        eulerOut === 0
          ? 'all 6 modes stable'
          : `${eulerOut} of 6 modes diverge`;
      status.textContent = `Δ = ${dt.toFixed(2)} — ZOH: all 6 modes stable, every Δ · forward Euler: ${eulerWord}`;
    }

    slider.addEventListener('input', draw);
    // Re-read palette when the color scheme flips.
    window
      .matchMedia('(prefers-color-scheme: dark)')
      .addEventListener('change', draw);
    draw();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEigenSlider);
  } else {
    initEigenSlider();
  }
</script>
