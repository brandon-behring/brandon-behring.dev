---
import StatusBadge from './StatusBadge.astro';
import { projectHref, type Project } from '../data/portfolio';

interface Cluster {
  slug: string;
  name: string;
  description: string;
  expanding?: boolean;
}

interface Props {
  cluster: Cluster;
  projects: Project[];
  /**
   * Compact variant for the homepage "More work" tier strip: omits the
   * artifact list, keeping just the header and the "More →" link so tier
   * tiles read as clearly secondary.
   */
  compact?: boolean;
}

const { cluster, projects, compact = false } = Astro.props;
---

<article class:list={["cluster-card", { compact }]}>
  <header>
    <h3>{cluster.name}</h3>
    <p class="cluster-description">{cluster.description}</p>
  </header>

  {!compact && (
    <ul class="artifact-list">
      {projects.map((p) => {
        const href = projectHref(p);
        return (
          <li class="artifact">
            <span class="artifact-bullet" aria-hidden="true">▪</span>
            {href ? (
              <a class="artifact-title artifact-link" href={href} rel="noopener">{p.title}</a>
            ) : (
              <span class="artifact-title">{p.title}</span>
            )}
            <StatusBadge status={p.status} />
          </li>
        );
      })}
      {cluster.expanding && (
        <li class="expanding-hint">
          <span class="artifact-bullet" aria-hidden="true">▫</span>
          <em>More books &amp; notes in progress</em>
        </li>
      )}
    </ul>
  )}

  <a href={`/work/${cluster.slug}/`} class="more-link">
    More <span aria-hidden="true">→</span>
    <span class="sr-only">about {cluster.name}</span>
  </a>
</article>

<style>
  .cluster-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--elevation-card);
    height: 100%;
  }

  .cluster-card.compact {
    gap: 0.75rem;
    padding: 1rem 1.25rem;
  }

  .cluster-card.compact h3 {
    font-size: 1rem;
  }

  .cluster-card.compact .cluster-description {
    font-size: 0.85rem;
  }

  .cluster-card h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.15rem;
    font-family: var(--font-sans);
  }

  .cluster-description {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .artifact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    flex: 1;
  }

  .artifact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .artifact-bullet {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .artifact-title {
    font-weight: 500;
    color: var(--color-text);
  }

  .artifact-link {
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.1s ease, border-color 0.1s ease;
  }
  .artifact-link:hover,
  .artifact-link:focus-visible {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .expanding-hint {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .expanding-hint .artifact-bullet {
    color: var(--color-text-muted);
  }

  .more-link {
    align-self: flex-start;
    color: var(--color-accent);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }

  .more-link:hover,
  .more-link:focus-visible {
    border-bottom-color: var(--color-accent);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
