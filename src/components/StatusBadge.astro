---
interface Props {
  status: string;
}
const { status } = Astro.props;

// Canonical 4-state taxonomy. Unknown values fall back to a neutral grey pill
// echoing the raw string, so an unmapped status is visible rather than silent.
const MAP: Record<string, { label: string; variant: string }> = {
  'released': { label: 'released', variant: 'released' },
  'in-progress': { label: 'in progress', variant: 'in-progress' },
  'prototype': { label: 'prototype', variant: 'prototype' },
  'planned': { label: 'planned', variant: 'planned' },
};
const { label, variant } = MAP[status] ?? { label: status, variant: 'unknown' };
---

<span class:list={["status-badge", `status-${variant}`]} aria-label={`Status: ${label}`}>{label}</span>

<style>
  .status-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    letter-spacing: 0.03em;
    text-transform: lowercase;
    line-height: 1.4;
    vertical-align: middle;
    border: 1px solid;
  }
  /* Colors come from the shared status tokens (tokens.css), which carry their own
     dark-scheme values — so this component needs no dark @media of its own. */
  .status-released {
    background: var(--status-released-bg);
    color: var(--status-released-fg);
    border-color: var(--status-released-border);
  }
  .status-in-progress {
    background: var(--status-progress-bg);
    color: var(--status-progress-fg);
    border-color: var(--status-progress-border);
  }
  .status-prototype {
    background: var(--status-prototype-bg);
    color: var(--status-prototype-fg);
    border-color: var(--status-prototype-border);
  }
  .status-planned,
  .status-unknown {
    background: var(--status-neutral-bg);
    color: var(--status-neutral-fg);
    border-color: var(--status-neutral-border);
  }
</style>
