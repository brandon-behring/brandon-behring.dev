---
import Base from '../../layouts/Base.astro';
import ClusterCard from '../../components/ClusterCard.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import { clustersInSection, projectsForCluster, visibleProjects } from '../../data/portfolio';

const nowClusters = clustersInSection('now');
const tierClusters = clustersInSection('tier');
const futureClusters = clustersInSection('future');

// Status legend: only show labels for statuses actually present among visible projects.
const visibleStatuses = new Set(visibleProjects.map((p) => p.status));
const legend = [
  { status: 'released', note: 'usable / published today' },
  { status: 'in-progress', note: 'actively being built' },
  { status: 'prototype', note: 'methodology demo, not productionized' },
  { status: 'planned', note: 'not started' },
].filter((l) => visibleStatuses.has(l.status));
---

<Base
  title="Work — Brandon Behring"
  description="Projects in causal inference, AI evaluation, sequence-model and RL foundations, and the research infrastructure behind them."
>
  <section class="work-intro prose">
    <h1>Work</h1>
    <p>
      Current work plus the infrastructure, research, and pricing systems
      behind it. Each links to a deeper page with per-project detail.
    </p>
    <p class="work-research-link">
      Prefer a thematic view? <a href="/research/">Explore the research threads →</a>
    </p>
    <p class="work-method">
      Substantive artifacts ship with a decision log and an independent audit —
      <a href="/how-this-was-made/">Methodology &amp; audit trail →</a>
    </p>
    <ul class="status-legend" aria-label="What the status labels mean">
      {legend.map((l) => (
        <li><StatusBadge status={l.status} /> {l.note}</li>
      ))}
    </ul>
  </section>

  {nowClusters.length > 0 && (
    <section class="clusters" aria-labelledby="work-now-heading">
      <h2 id="work-now-heading" class="prose section-heading">Current work</h2>
      <div class="cluster-grid">
        {nowClusters.map((cluster) => (
          <ClusterCard
            cluster={cluster}
            projects={projectsForCluster(cluster.slug)}
          />
        ))}
      </div>
    </section>
  )}

  {tierClusters.length > 0 && (
    <section class="clusters" aria-labelledby="work-more-heading">
      <h2 id="work-more-heading" class="prose section-heading">More work</h2>
      <div class="cluster-grid">
        {tierClusters.map((cluster) => (
          <ClusterCard
            cluster={cluster}
            projects={projectsForCluster(cluster.slug)}
          />
        ))}
      </div>
    </section>
  )}

  {futureClusters.length > 0 && (
    <section class="clusters" aria-labelledby="work-future-heading">
      <h2 id="work-future-heading" class="prose section-heading">Where this is going</h2>
      <div class="cluster-grid">
        {futureClusters.map((cluster) => (
          <ClusterCard
            cluster={cluster}
            projects={projectsForCluster(cluster.slug)}
          />
        ))}
      </div>
    </section>
  )}
</Base>

<style>
  .work-intro {
    margin: 2rem auto 3rem auto;
  }
  .work-intro h1 {
    margin-bottom: 0.5rem;
  }
  .work-research-link {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
  }
  .work-method {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
  }
  .status-legend {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .status-legend li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .clusters {
    margin: 3rem 0;
  }
  .section-heading {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  .cluster-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .cluster-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .cluster-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
