---
import Base from '../../layouts/Base.astro';
import ClusterCard from '../../components/ClusterCard.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import clustersData from '../../data/clusters.json';
import projectsData from '../../data/projects.json';

const nowClusters = clustersData
  .filter((c) => c.section === 'now')
  .sort((a, b) => a.order - b.order);

const tierClusters = clustersData
  .filter((c) => c.section === 'tier')
  .sort((a, b) => a.order - b.order);

const futureClusters = clustersData
  .filter((c) => c.section === 'future')
  .sort((a, b) => a.order - b.order);

function projectsForCluster(slug: string) {
  return projectsData
    .filter((p) => p.cluster === slug)
    .sort((a, b) => a.order - b.order);
}
---

<Base
  title="Work — Brandon Behring"
  description="Projects in applied causal methods, AI evaluation, and course-derived study notes."
>
  <section class="work-intro prose">
    <h1>Work</h1>
    <p>
      Current work plus the infrastructure, research, and pricing systems
      behind it. Each links to a deeper page with per-project detail.
    </p>
    <ul class="status-legend" aria-label="What the status labels mean">
      <li><StatusBadge status="released" /> usable / published today</li>
      <li><StatusBadge status="in-progress" /> actively being built</li>
      <li><StatusBadge status="prototype" /> methodology demo, not productionized</li>
      <li><StatusBadge status="planned" /> not started</li>
    </ul>
  </section>

  <section class="clusters" aria-labelledby="work-now-heading">
    <h2 id="work-now-heading" class="prose section-heading">Current work</h2>
    <div class="cluster-grid">
      {nowClusters.map((cluster) => (
        <ClusterCard
          cluster={cluster}
          projects={projectsForCluster(cluster.slug)}
        />
      ))}
    </div>
  </section>

  <section class="clusters" aria-labelledby="work-more-heading">
    <h2 id="work-more-heading" class="prose section-heading">More work</h2>
    <div class="cluster-grid">
      {tierClusters.map((cluster) => (
        <ClusterCard
          cluster={cluster}
          projects={projectsForCluster(cluster.slug)}
        />
      ))}
    </div>
  </section>

  <section class="clusters" aria-labelledby="work-future-heading">
    <h2 id="work-future-heading" class="prose section-heading">Where this is going</h2>
    <div class="cluster-grid">
      {futureClusters.map((cluster) => (
        <ClusterCard
          cluster={cluster}
          projects={projectsForCluster(cluster.slug)}
        />
      ))}
    </div>
  </section>
</Base>

<style>
  .work-intro {
    margin: 2rem auto 3rem auto;
  }
  .work-intro h1 {
    margin-bottom: 0.5rem;
  }
  .status-legend {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .status-legend li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .clusters {
    margin: 3rem 0;
  }
  .section-heading {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  .cluster-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .cluster-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .cluster-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
