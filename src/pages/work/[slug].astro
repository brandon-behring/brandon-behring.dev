---
import Base from '../../layouts/Base.astro';
import ClusterNav from '../../components/ClusterNav.astro';
import ProjectSection from '../../components/ProjectSection.astro';
import { visibleClusters, projectsForCluster } from '../../data/portfolio';

export function getStaticPaths() {
  return visibleClusters.map((cluster) => ({
    params: { slug: cluster.slug },
    props: { cluster },
  }));
}

interface ClusterShape {
  slug: string;
  name: string;
  description: string;
  expanding?: boolean;
}

const { cluster } = Astro.props as { cluster: ClusterShape };

const projects = projectsForCluster(cluster.slug);
---

<Base
  title={`${cluster.name} — Brandon Behring`}
  description={cluster.description}
>
  <div class="cluster-page">
    <ClusterNav currentSlug={cluster.slug} />

    <div class="cluster-page-header">
      <h1>{cluster.name}</h1>
      <p class="cluster-intro">{cluster.description}</p>
    </div>

    {projects.map((project) => (
      <ProjectSection project={project} />
    ))}

    {cluster.expanding && (
      <section class="more-coming">
        <h2>More coming</h2>
        <p>
          {cluster.name} is an active and expanding cluster. More
          course-derived books from other technical sources are lined up
          (Bertsekas RL + control, ssm-foundations chapters, and others).
        </p>
      </section>
    )}

    <p class="back-link">
      <a href="/work/">← Work</a> · <a href="/">← Home</a>
    </p>
  </div>
</Base>

<style>
  /* Roomier than the 65ch reading column — structured project content uses more
     of the desktop width without going full-bleed (#29). Global .prose unchanged. */
  .cluster-page {
    max-width: var(--max-width-content);
    margin-left: auto;
    margin-right: auto;
  }
  .cluster-page-header {
    margin: 1rem 0 2rem 0;
  }
  .cluster-page-header h1 {
    margin-bottom: 0.5rem;
  }
  .cluster-intro {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    line-height: 1.5;
    margin: 0;
  }
  .more-coming {
    margin: 3rem 0;
    padding: 1.5rem;
    border: 1px dashed var(--color-border);
    border-radius: 4px;
  }
  .more-coming h2 {
    margin-top: 0;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .more-coming p {
    margin-bottom: 0;
  }
  .back-link {
    margin-top: 3rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }
</style>
