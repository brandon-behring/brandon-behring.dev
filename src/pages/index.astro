---
import Base from '../layouts/Base.astro';
import ClusterCard from '../components/ClusterCard.astro';
import clustersData from '../data/clusters.json';
import projectsData from '../data/projects.json';

const nowClusters = clustersData
  .filter((c) => c.section === 'now')
  .sort((a, b) => a.order - b.order);

function projectsForCluster(slug: string) {
  return projectsData
    .filter((p) => p.cluster === slug)
    .sort((a, b) => a.order - b.order);
}
---

<Base
  title="Brandon Behring — Applied Causal Methods + AI Evaluation"
  description="Brandon Behring builds applied causal methods, AI evaluation tooling, and a study notes corpus."
>
  <section class="hero prose">
    <h1>Brandon Behring</h1>
    <p class="hero-tagline">
      Building applied causal methods, AI evaluation tooling, and a study notes corpus.
    </p>
  </section>

  <section class="live-now" aria-labelledby="live-heading">
    <h2 id="live-heading" class="section-heading">Live now</h2>
    <ul class="live-list">
      <li>
        <a href="https://ssm-foundations.brandon-behring.dev" rel="noopener">
          ssm-foundations <span>sequence-models foundations book</span>
        </a>
      </li>
      <li>
        <a href="https://dml.brandon-behring.dev" rel="noopener">
          double_ml_time_series <span>Chapter 1 live</span>
        </a>
      </li>
      <li>
        <a href="/lab/research-graph/">
          RL + Control citation graph <span>interactive demo</span>
        </a>
      </li>
      <li>
        <a href="https://brandon-behring.github.io/prompt-injection-detection-prototype/" rel="noopener">
          Prompt-injection OOD study <span>deployed docs</span>
        </a>
      </li>
    </ul>
  </section>

  <section class="clusters" aria-labelledby="now-heading">
    <h2 id="now-heading" class="prose section-heading">What I'm building now</h2>
    <div class="cluster-grid">
      {nowClusters.map((cluster) => (
        <ClusterCard
          cluster={cluster}
          projects={projectsForCluster(cluster.slug)}
        />
      ))}
    </div>
    <p class="see-all">
      <a class="see-all-primary" href="/work/">See all work →</a>
      <a class="see-all-teaser" href="/work/#work-future-heading">Where this is going →</a>
    </p>
  </section>

  <section id="about" class="bio prose" aria-labelledby="about-heading">
    <h2 id="about-heading">About</h2>
    <p>
      Currently working through post-transformer sequence model
      architectures (SSMs, Mamba, Hyena, DeltaNet) and reinforcement
      learning + optimal control. Expanding the course-derived study notes
      pattern beyond DLAI. Direction: research engineering on next-generation
      AI architectures, with applied causal methods, risk analysis,
      and rigorous evaluation as the methodology spine.
    </p>
    <p class="about-methodology">
      Methodology, AI disclosure, and audit trail:
      <a href="/how-this-was-made/">How this was made →</a>
    </p>
    <p class="about-methodology">
      Earlier peer-reviewed research:
      <a href="/publications/">Publications →</a>
    </p>
  </section>

  <section id="contact" class="contact prose" aria-labelledby="contact-heading">
    <h2 id="contact-heading">Contact</h2>
    <ul class="contact-list">
      <li><strong>Email:</strong> <a href="mailto:brandon.m.behring@gmail.com">brandon.m.behring@gmail.com</a></li>
      <li><strong>GitHub:</strong> <a href="https://github.com/brandon-behring">@brandon-behring</a></li>
      <li><strong>LinkedIn:</strong> <a href="https://www.linkedin.com/in/brandon-behring/">/in/brandon-behring</a></li>
    </ul>
  </section>
</Base>

<style>
  .hero {
    margin: 2rem auto 3rem auto;
  }
  .hero h1 {
    margin-bottom: 0.75rem;
  }
  .hero-tagline {
    font-size: 1.25rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    margin: 0;
    line-height: 1.4;
  }

  .live-now {
    margin: 0 auto 3rem auto;
  }
  .live-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-family: var(--font-sans);
  }
  .live-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.1s ease, color 0.1s ease;
  }
  .live-list a::before {
    content: "";
    flex: 0 0 auto;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: #2e9e5b;
  }
  .live-list a:hover,
  .live-list a:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
    outline: none;
  }
  .live-list a span {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
  .live-list a:hover span,
  .live-list a:focus-visible span {
    color: inherit;
  }

  .clusters {
    margin: 3rem 0;
  }
  .section-heading {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .cluster-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .cluster-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .cluster-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .see-all {
    margin: 2rem 0 0 0;
    font-family: var(--font-sans);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    align-items: baseline;
  }
  .see-all-primary {
    font-size: 1.05rem;
    font-weight: 600;
  }
  .see-all-teaser {
    font-size: 0.9rem;
  }

  .bio,
  .contact {
    margin: 3rem auto;
  }
  .about-methodology {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  .contact-list {
    list-style: none;
    padding-left: 0;
    font-family: var(--font-sans);
  }
  .contact-list li {
    margin: 0.5rem 0;
  }
</style>
