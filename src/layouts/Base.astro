---
import Header from '../components/Header.astro';
import '../styles/tokens.css';

type HeaderVariant = "full" | "minimal";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  headerVariant?: HeaderVariant;
  /**
   * If true, omits the `<main>` max-width wrapper so the page can use
   * full-bleed layouts (e.g., /lab/research-graph/'s Cytoscape viewport).
   * Default false → editorial max-width 1200px applies.
   */
  fullBleed?: boolean;
  /** If true, hides the site footer (for full-bleed lab pages). Default false. */
  hideFooter?: boolean;
}
const {
  title,
  description = "Brandon Behring builds causal-inference and AI-evaluation tooling, foundations books on sequence models and reinforcement learning, and the research infrastructure beneath them.",
  ogImage = "/og-image.png",
  headerVariant = "full",
  fullBleed = false,
  hideFooter = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

// Site-global identity, emitted on every page as a JSON-LD graph. Everything here is
// factual and publicly verifiable; `sameAs` + `alumniOf` reinforce search-engine entity
// resolution (disambiguating the academic namesake). No jobTitle — the site states none.
const siteOrigin = Astro.site?.href ?? "https://brandon-behring.dev/";
const personId = new URL("#person", Astro.site).href;
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": personId,
  name: "Brandon Behring",
  url: siteOrigin,
  description:
    "Builds causal-inference and AI-evaluation tooling, foundations books on sequence models and reinforcement learning, and the research infrastructure beneath them.",
  image: new URL("/og-image.png", Astro.site).href,
  sameAs: [
    "https://github.com/brandon-behring",
    "https://www.linkedin.com/in/brandon-behring/",
    "https://scholar.google.com/citations?user=M1LzNAgAAAAJ",
  ],
  alumniOf: [
    {
      "@type": "CollegeOrUniversity",
      name: "New Jersey Institute of Technology",
      sameAs: "https://en.wikipedia.org/wiki/New_Jersey_Institute_of_Technology",
    },
    {
      "@type": "CollegeOrUniversity",
      name: "New York University",
      sameAs: "https://en.wikipedia.org/wiki/New_York_University",
    },
  ],
};
const siteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": new URL("#website", Astro.site).href,
  url: siteOrigin,
  name: "Brandon Behring",
  creator: { "@id": personId },
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Brandon Behring" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph / social previews -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="preload" href="/fonts/fraunces-vf.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="alternate" type="application/rss+xml" title="Brandon Behring — new work" href="/rss.xml" />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(siteLd)} />

  <!--
    Cloudflare Web Analytics is auto-injected at the edge for the
    CF-proxied production domain (brandon-behring.dev) — no inline
    beacon script needed. workers.dev preview gets no analytics by
    design; that's acceptable since it's not the public surface.
  -->
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>

  <Header variant={headerVariant} />

  <main id="main" class:list={[{ 'full-bleed': fullBleed }]}>
    <slot />
  </main>

  {!hideFooter && (
    <footer>
      <div class="footer-inner">
        <p>
          © 2026 Brandon Behring · <a href="mailto:brandon.m.behring@gmail.com">brandon.m.behring@gmail.com</a> ·
          <a href="https://github.com/brandon-behring">GitHub</a> ·
          <a href="https://www.linkedin.com/in/brandon-behring/">LinkedIn</a> ·
          <a href="/publications/">Publications</a>
        </p>
      </div>
    </footer>
  )}
</body>
</html>

<style is:global>
  /* Design tokens live in src/styles/tokens.css (imported in the frontmatter). */
  html { font-family: var(--font-prose); color: var(--color-text); background: var(--color-bg); line-height: 1.6; }
  body { margin: 0; padding: 0; }
  main {
    max-width: var(--max-width-wide);
    margin: 2rem auto 2rem auto;
    padding: 0 1.5rem;
  }
  main.full-bleed {
    max-width: none;
    margin: 0;
    padding: 0;
  }
  /* Utility: editorial-width text within a wider main */
  .prose {
    max-width: var(--max-width-prose);
    margin-left: auto;
    margin-right: auto;
  }
  footer {
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.9em;
    font-family: var(--font-sans);
    margin-top: 4rem;
  }
  /* Quiet the footer link run: color-only, underline on hover (audit P3). */
  footer a { text-decoration: none; }
  footer a:hover, footer a:focus-visible { text-decoration: underline; }
  .footer-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 1.5rem;
  }
  h1, h2, h3 { font-weight: 600; line-height: 1.2; }
  h1 { font-family: var(--font-display); font-optical-sizing: auto; font-weight: 540; letter-spacing: -0.01em; font-size: 2.25rem; margin-top: 0; }
  h2, h3 { font-family: var(--font-sans); }
  h2 { font-size: 1.5rem; margin-top: 2.5rem; }
  h3 { font-size: 1.15rem; margin-top: 1.5rem; }
  a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px; }
  a:hover { text-decoration-thickness: 2px; }
  a:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; border-radius: 2px; }
  /* Inline-code chip — warm tinted fill + hairline border for a defined boundary.
     Scheme flips via tokens (tokens.css). :not(pre) guards future fenced blocks. */
  :not(pre) > code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-code-border);
    border-radius: var(--radius-sm);
    padding: 0.1em 0.35em;
  }

  /* Fulcrum-rule: signature section divider — a hairline with one off-center
     accent tick (~38% from left). A subtle nod to the rigor-as-fulcrum thesis;
     reads as a tasteful divider regardless. */
  .fulcrum-rule {
    position: relative;
    height: 1px;
    border: 0;
    background: var(--color-border);
    margin: var(--space-12, 3rem) 0;
  }
  .fulcrum-rule::after {
    content: "";
    position: absolute;
    left: 38%;
    top: -2.5px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* Skip-to-content link for keyboard / screen-reader users */
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--color-accent);
    color: var(--color-on-accent);
    padding: 0.5rem 1rem;
    z-index: 100;
    text-decoration: none;
  }
  .skip-link:focus {
    left: 0;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
